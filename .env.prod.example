# ============================================================
# Variáveis de PRODUÇÃO — copie para .env no servidor e ajuste.
# (Não versione o .env real; ele contém segredos.)
# ============================================================

# --- Traefik / SSL ---
# Domínio que aponta (DNS A/AAAA) para o servidor. Frontend em /, API em /api.
DOMAIN=requerimentos.seudominio.com.br
# E-mail usado pelo Let's Encrypt (avisos de expiração do certificado).
ACME_EMAIL=contato@seudominio.com.br
# Token da API Cloudflare para o desafio DNS-01 (não usa portas de entrada).
# Crie em: Cloudflare > My Profile > API Tokens > Create Token.
# Permissões: Zone > DNS > Edit  e  Zone > Zone > Read  (escopo: a zona do domínio).
CF_DNS_API_TOKEN=seu_token_cloudflare

# --- Banco de dados (Postgres) ---
POSTGRES_DB=pmro_requerimentos
POSTGRES_USER=pmro_user
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
# Aponta para o serviço "db" na rede interna (não publicado externamente).
DATABASE_URL=postgresql://pmro_user:TROQUE_POR_UMA_SENHA_FORTE@db:5432/pmro_requerimentos

# --- Backend / Auth ---
SECRET_KEY=TROQUE_POR_UMA_CHAVE_ALEATORIA_LONGA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
# Mesma origem (frontend e API no mesmo domínio) — informe a URL pública por segurança.
BACKEND_CORS_ORIGINS=https://requerimentos.seudominio.com.br

# Usuário administrador criado no primeiro start (defina senha forte!).
INITIAL_ADMIN_NAME=Administrador PMRO
INITIAL_ADMIN_EMAIL=admin@seudominio.com.br
INITIAL_ADMIN_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE

# --- Frontend (build) ---
# Domínio único: caminho relativo (mesma origem). Não precisa do domínio aqui.
VITE_API_BASE_URL=/api/v1
